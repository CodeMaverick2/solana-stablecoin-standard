# ============================================================
# Solana Stablecoin Standard — Backend Configuration
# Copy this file to .env and fill in values for your deployment.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Solana RPC ---
# HTTP JSON-RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com
# WebSocket endpoint (for event subscriptions)
SOLANA_WS_URL=wss://api.devnet.solana.com
# Commitment level: processed | confirmed | finalized
SOLANA_COMMITMENT=confirmed

# --- Program IDs ---
STABLECOIN_PROGRAM_ID=B1zqgaJkbVzNoMagPyAJdgveArzaTW6fkyk3JtSq1pHs
TRANSFER_HOOK_PROGRAM_ID=HgSUZDiLt8UWwzaxhCWwLPPs9zB1F7WTzCFSVmQSaLou

# --- Stablecoin Mint ---
# The Token-2022 mint address for this stablecoin instance.
# Required for event listening and supply queries.
STABLECOIN_MINT=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Webhook ---
# Maximum retry attempts for failed webhook deliveries
WEBHOOK_MAX_RETRIES=5
# Base delay in milliseconds for exponential backoff
WEBHOOK_BASE_DELAY_MS=1000
# Timeout in milliseconds for webhook HTTP requests
WEBHOOK_TIMEOUT_MS=10000
